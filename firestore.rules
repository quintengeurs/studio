rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && request.auth.token.email.matches('(?i)quinten.geurs@gmail.com');
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userDoc = get(userPath);
      return userDoc.exists ? userDoc.data : {"orgId": "hackney-council"};
    }

    function userOrgId() {
      return getUserData().orgId;
    }

    function hasOrgAccess(data) {
      return isAuth() && (isMaster() || (data != null && data.orgId == userOrgId()));
    }

    function hasOrgAccessForWrite() {
      return isAuth() && (isMaster() || request.resource.data.orgId == userOrgId());
    }

    // =============================================
    // Users
    // =============================================
    match /users/{userId} {
      allow read:   if isMaster() || request.auth.uid == userId;
      allow create: if true;
      allow update: if isMaster() || request.auth.uid == userId;
      allow delete: if isMaster();
    }

    // =============================================
    // Organizations
    // =============================================
    match /organizations/{orgId} {
      allow read:  if true;                    // Public for branding
      allow write: if isMaster();

      match /role_templates/{roleId} {
        allow read:  if isAuth();
        allow write: if isMaster();
      }
    }

    // =============================================
    // Global / Public-ish
    // =============================================
    match /settings/registry {
      allow read:  if isAuth();
      allow write: if isMaster();
    }

    match /locations/{locationId} {
      allow read:  if isAuth();
      allow write: if hasOrgAccessForWrite();
    }

    // =============================================
    // Main app collections
    // =============================================
    match /park_activities/{activityId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.type == 'Volunteering' && resource.data.status == 'Confirmed');
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /tasks/{taskId} {
      allow read:   if hasOrgAccess(resource.data) || resource.data.isVolunteerEligible == true;
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /info_items/{itemId} {
      allow read:   if resource.data.isVolunteerVisible == true || hasOrgAccess(resource.data);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedUserIds']);
      allow create, delete: if hasOrgAccessForWrite();
    }

    match /issues/{issueId}     { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /assets/{assetId}     { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /requests/{requestId} { allow read, create, update, delete: if isMaster() || hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }

    // Detail collections
    match /parks_details/{docId}   { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /depots_details/{docId}  { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /machinery/{docId}       { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /smart_rules/{docId}     { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }

    // =============================================
    // Volunteering
    // =============================================
    match /volunteers/{volunteerId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // =============================================
    // Master fallback
    // =============================================
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}