rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && request.auth.token.email == 'quinten.geurs@gmail.com';
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"orgId": "none"};
    }

    function belongsToOrg(orgId) {
      return isAuth() && (getUserData().orgId == orgId || isMaster());
    }

    function matchOrgId(data) {
      return isAuth() && (
        isMaster() || 
        (data.orgId != null && data.orgId == getUserData().orgId) || 
        // Fallback: If document has no orgId, allow access for the primary 'hackney-council' tenant admins
        (!('orgId' in data) && getUserData().orgId == 'hackney-council')
      );
    }

    // Rules for user management
    match /users/{userId} {
      allow read: if isAuth() && (isMaster() || request.auth.uid == userId || resource.data.orgId == getUserData().orgId);
      allow create: if true; 
      allow update, delete: if isAuth() && (isMaster() || request.auth.uid == userId || resource.data.orgId == getUserData().orgId);
    }

    // Rules for organizations
    match /organizations/{orgId} {
      allow read: if isAuth() && (getUserData().orgId == orgId || isMaster());
      allow write: if isMaster();
    }

    // Rules for settings/registry
    match /settings/{orgId} {
      allow read: if isAuth() && (getUserData().orgId == orgId || isMaster());
      allow write: if isAuth() && (getUserData().orgId == orgId || isMaster());
    }

    // Rules for tasks
    match /tasks/{taskId} {
      allow read: if isAuth() && matchOrgId(resource.data);
      allow create: if isAuth() && matchOrgId(request.resource.data);
      allow update, delete: if isAuth() && matchOrgId(resource.data);
    }

    // Rules for issues
    match /issues/{issueId} {
      allow read: if isAuth() && matchOrgId(resource.data);
      allow create: if isAuth() && matchOrgId(request.resource.data);
      allow update, delete: if isAuth() && matchOrgId(resource.data);
    }

    // Rules for assets
    match /assets/{assetId} {
      allow read: if isAuth() && matchOrgId(resource.data);
      allow create: if isAuth() && matchOrgId(request.resource.data);
      allow update, delete: if isAuth() && matchOrgId(resource.data);
    }

    // Rules for requests
    match /requests/{requestId} {
      allow read: if isAuth() && matchOrgId(resource.data);
      allow create: if isAuth() && matchOrgId(request.resource.data);
      allow update, delete: if isAuth() && (isMaster() || matchOrgId(resource.data));
    }

    // Rules for parks_details
    match /parks_details/{parkId} {
      allow read: if isAuth() && (resource.data.orgId == getUserData().orgId || isMaster());
      allow create, update, delete: if isAuth() && (request.resource.data.orgId == getUserData().orgId || isMaster());
    }

    // Public Volunteering Portal
    match /volunteers/{volunteerId} {
      allow create: if true;
      allow read, update, delete: if isAuth(); 
    }

    match /info_items/{itemId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && matchOrgId(resource.data);
    }

    // Rules for action_logs
    match /action_logs/{logId} {
      allow read: if isAuth() && (isMaster() || resource.data.orgId == getUserData().orgId);
      allow create: if isAuth(); 
      allow update, delete: if false; // Logs are immutable
    }

    // Catch-all rule
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}
