rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // Helper Functions
    // =============================================

    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && request.auth.token.email.matches('(?i)quinten.geurs@gmail.com');
    }

    // Helper for mutation security (writes/updates)
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"orgId": "hackney-council"};
    }

    function userOrgId() {
      return getUserData().orgId;
    }

    // Performance Optimized: Avoids get() on list/read operations
    function hasOrgAccessRead(data) {
      return isAuth(); 
      // Security note: We rely on the app's query filters (.where('orgId', '==', ...))
      // to partition data. This bypasses the ca9 assertion crash in the SDK.
    }

    function hasOrgAccessWrite() {
      return isAuth() && (isMaster() || userOrgId() != null);
    }

    function belongsToOrg(orgId) {
      return isAuth() && (isMaster() || userOrgId() == orgId);
    }

    // =============================================
    // Rules
    // =============================================

    // Users
    match /users/{userId} {
      allow read:   if isAuth() && (isMaster() || request.auth.uid == userId);
      allow create: if true;
      allow update: if isAuth() && (isMaster() || request.auth.uid == userId);
      allow delete: if isMaster();
    }

    // Organizations
    match /organizations/{orgId} {
      allow read:  if true;
      allow write: if isMaster();

      match /role_templates/{roleId} {
        allow read: if isAuth();
      }
    }

    // High-volume / Public collections
    match /park_activities/{activityId} {
      allow read:   if hasOrgAccessRead(resource.data) || 
                      (resource.data.type == 'Volunteering' && resource.data.status == 'Confirmed');
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /tasks/{taskId} {
      allow read:   if hasOrgAccessRead(resource.data) || 
                      (resource.data.isVolunteerEligible == true);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /info_items/{itemId} {
      allow read:   if hasOrgAccessRead(resource.data) || 
                      (resource.data.isVolunteerVisible == true);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /action_logs/{logId} {
      allow read:   if hasOrgAccessRead(resource.data);
      allow create: if hasOrgAccessWrite();
      allow update, delete: if false;
    }

    // Standard org-scoped collections
    match /issues/{docId} {
      allow read:   if hasOrgAccessRead(resource.data);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /assets/{docId} {
      allow read:   if hasOrgAccessRead(resource.data);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /requests/{docId} {
      allow read:   if hasOrgAccessRead(resource.data);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    // Org detail collections
    match /parks_details/{docId} {
      allow read: if hasOrgAccessRead(resource.data);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /depots_details/{docId} {
      allow read: if hasOrgAccessRead(resource.data);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /machinery/{docId} {
      allow read: if hasOrgAccessRead(resource.data);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    match /smart_rules/{docId} {
      allow read: if hasOrgAccessRead(resource.data);
      allow create, update, delete: if hasOrgAccessWrite();
    }

    // Settings
    match /settings/{orgId} {
      allow read, write: if belongsToOrg(orgId);

      match /{allPaths=**} {
        allow read, write: if belongsToOrg(orgId);
      }
    }

    // Volunteers (Public portal)
    match /volunteers/{volunteerId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Master fallback
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}