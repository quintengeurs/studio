rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // Helper Functions
    // =============================================
    
    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && (
        request.auth.token.email.matches('(?i)quinten.geurs@gmail.com') ||
        request.auth.token.email.matches('(?i)quinten.geurs@hackney.gov.uk')
      );
    }

    function getClaimOrgId() {
      return request.auth.token.orgId;
    }

    function getClaimRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isMaster() || getClaimRole() == 'Admin';
    }

    function hasOrgAccess(data) {
      return isAuth() && (
        isMaster() || 
        (data != null && data.orgId == getClaimOrgId())
      );
    }

    function hasOrgAccessForWrite() {
      return isAuth() && (
        isMaster() || 
        request.resource.data.orgId == getClaimOrgId()
      );
    }

    // =============================================
    // Users
    // =============================================
    match /users/{userId} {
      allow read:   if isMaster() || request.auth.uid == userId;
      allow create: if isAuth();
      allow update: if isMaster() || request.auth.uid == userId;
      allow delete: if isMaster();
    }

    // =============================================
    // Organizations
    // =============================================
    match /organizations/{orgId} {
      allow read:  if true;
      allow write: if isMaster();

      match /role_templates/{roleId} {
        allow read:  if isAuth();
        allow write: if isAdmin() && orgId == getClaimOrgId();
      }
    }

    match /settings/registry {
      allow read:  if isAuth();
      allow write: if isMaster();
    }

    // =============================================
    // Main Operational Collections
    // =============================================
    match /park_activities/{activityId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.get('type', '') == 'Volunteering' && resource.data.get('status', '') == 'Confirmed');
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /tasks/{taskId} {
      allow read:   if hasOrgAccess(resource.data) || resource.data.get('isVolunteerEligible', false) == true;
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /info_items/{itemId} {
      allow read:   if resource.data.get('isVolunteerVisible', false) == true || hasOrgAccess(resource.data);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedUserIds']);
      allow create, delete: if hasOrgAccessForWrite();
    }

    match /issues/{issueId}     { allow read: if hasOrgAccess(resource.data); allow create, update, delete: if hasOrgAccessForWrite(); }
    match /assets/{assetId}     { allow read: if hasOrgAccess(resource.data); allow create, update, delete: if hasOrgAccessForWrite(); }
    match /requests/{requestId} { allow read: if hasOrgAccess(resource.data); allow create, update, delete: if isMaster() || hasOrgAccessForWrite(); }

    // Detail collections
    match /parks_details/{docId}   { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /depots_details/{docId}  { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /machinery/{docId}       { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }
    match /smart_rules/{docId}     { allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite(); }

    // Locations
    match /locations/{locationId} {
      allow read:  if isAuth();
      allow write: if hasOrgAccessForWrite();
    }

    // Volunteering
    match /volunteers/{volunteerId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Master fallback
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}