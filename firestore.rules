rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // Helper Functions
    // =============================================

    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && request.auth.token.email.matches('(?i)quinten.geurs@gmail.com');
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userDoc = get(userPath);
      return userDoc.exists ? userDoc.data : {"orgId": "hackney-council"};
    }

    function userOrgId() {
      return getUserData().orgId;
    }

    function hasOrgAccess(data) {
      return isAuth() && (
        isMaster() || 
        (data != null && data.orgId == userOrgId())
      );
    }

    function hasOrgAccessForWrite() {
      return isAuth() && (
        isMaster() || 
        (request.resource.data.orgId == userOrgId())
      );
    }

    function belongsToOrg(orgId) {
      return isAuth() && (userOrgId() == orgId || isMaster());
    }

    // =============================================
    // Rules
    // =============================================

    // Users
    match /users/{userId} {
      allow read:   if isMaster() || request.auth.uid == userId;
      allow create: if true;
      allow update: if isMaster() || request.auth.uid == userId;
      allow delete: if isMaster();
    }

    // Organizations
    match /organizations/{orgId} {
      allow read:  if true;
      allow write: if isMaster();

      match /role_templates/{roleId} {
        allow read:  if belongsToOrg(orgId);
        allow write: if belongsToOrg(orgId) && getUserData().role == 'Admin';
      }
    }

    // High-volume / Public-ish collections
    match /park_activities/{activityId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.type == 'Volunteering' && resource.data.status == 'Confirmed');
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /tasks/{taskId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.isVolunteerEligible == true);
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /info_items/{itemId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.isVolunteerVisible == true);
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /action_logs/{logId} {
      allow read:   if isMaster() || hasOrgAccess(resource.data);
      allow create: if hasOrgAccessForWrite();
      allow update, delete: if false;
    }

    // Standard org-scoped collections (split because | is not supported)
    match /issues/{docId} {
      allow read:   if hasOrgAccess(resource.data);
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /assets/{docId} {
      allow read:   if hasOrgAccess(resource.data);
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /requests/{docId} {
      allow read, create, update, delete: if isMaster() || hasOrgAccess(resource.data) || hasOrgAccessForWrite();
    }

    // Org detail collections
    match /parks_details/{docId} {
      allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite();
    }

    match /depots_details/{docId} {
      allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite();
    }

    match /machinery/{docId} {
      allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite();
    }

    match /smart_rules/{docId} {
      allow read, create, update, delete: if hasOrgAccess(resource.data) || hasOrgAccessForWrite();
    }

    // Settings
    match /settings/{orgId} {
      allow read, write: if belongsToOrg(orgId);

      match /{allPaths=**} {
        allow read, write: if belongsToOrg(orgId);
      }
    }

    // Volunteers (Public portal)
    match /volunteers/{volunteerId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Master fallback
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}