rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // Helper Functions
    // =============================================

    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && request.auth.token.email.matches('(?i)quinten.geurs@gmail.com');
    }

    // =============================================
    // Core Collections
    // =============================================

    // Users
    match /users/{userId} {
      allow read, create: if true;
      allow update, delete: if isAuth() && (isMaster() || request.auth.uid == userId);
    }

    // Organizations & Settings
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if isMaster();
    }

    match /settings/{docId} {
      allow read, write: if isAuth();
    }

    // =============================================
    // Volunteering & Public Hub
    // =============================================

    match /tasks/{taskId} {
      // Allow authenticated staff OR public volunteer-eligible tasks
      allow read: if isAuth() || resource.data.isVolunteerEligible == true;
      allow write: if isAuth();
    }

    match /info_items/{itemId} {
      // 1. Allow volunteers/public to see news items marked as 'Volunteer Visible'
      allow read: if isAuth() || resource.data.isVolunteerVisible == true;
      
      // 2. Allow volunteers to click the 'Interested' button (updates only that field)
      allow update: if isAuth() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedUserIds'])
      );
      
      allow create, delete: if isAuth();
    }

    // =============================================
    // Operational Data (Issues, Assets, Logs, etc.)
    // =============================================

    match /action_logs/{logId} {
      allow read, create: if isAuth();
      allow update, delete: if false;
    }

    // Batch rule for standard collections
    match /{collection}/{docId} {
      allow read, write: if isAuth();
      
      // List of collections covered by this catch-all:
      // issues, assets, machinery, smart_rules, requests, parks_details, depots_details, locations
    }

    // =============================================
    // Master Fallback
    // =============================================
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}