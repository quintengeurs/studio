rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // Helper Functions (Custom Claims Optimized)
    // =============================================
    
    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && (
        request.auth.token.email.matches('(?i)quinten.geurs@gmail.com') ||
        request.auth.token.email.matches('(?i)quinten.geurs@hackney.gov.uk')
      );
    }

    // Uses Firebase Auth Custom Claims for instant, zero-fetch verification
    function getClaimOrgId() {
      return request.auth.token.orgId;
    }

    function getClaimRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isMaster() || getClaimRole() == 'Admin';
    }

    // High-performance check for multi-tenancy
    function hasOrgAccess(data) {
      return isAuth() && (isMaster() || (data != null && data.orgId == getClaimOrgId()));
    }

    // For writes, we verify the user is putting the right orgId on the document
    function hasOrgAccessForWrite() {
      return isAuth() && (isMaster() || request.resource.data.orgId == getClaimOrgId());
    }

    // =============================================
    // Users
    // =============================================
    match /users/{userId} {
      // Allow read if UID matches OR if email matches (for email-based profiles)
      allow read:   if isAuth() && (
                      isMaster() || 
                      request.auth.uid == userId || 
                      request.auth.token.email.lower() == userId.lower() ||
                      resource.data.email.lower() == request.auth.token.email.lower()
                    );
      
      allow create: if isAuth(); // Usually handled by adminCreateUser function
      
      allow update: if isAuth() && (
                      isMaster() || 
                      request.auth.uid == userId || 
                      request.auth.token.email.lower() == userId.lower()
                    );
      
      allow delete: if isMaster();
    }

    // =============================================
    // Organizations & Configuration
    // =============================================
    match /organizations/{orgId} {
      allow read:  if true; 
      allow write: if isMaster();

      match /role_templates/{roleId} {
        allow read:  if isAuth();
        allow write: if isAdmin() && orgId == getClaimOrgId();
      }
    }

    match /settings/registry {
      allow read:  if isAuth();
      allow write: if isMaster();
    }

    match /locations/{locationId} {
      allow read:  if isAuth();
      allow write: if isAdmin() && hasOrgAccessForWrite();
    }

    // =============================================
    // Operational Data (Optimized for Query)
    // =============================================
    
    // We use a baseline of 'isAuth()' for many READS to prevent Evaluate crashes
    // while keeping WRITES strictly scoped by organization claim.

    match /park_activities/{activityId} {
      allow read:   if isAuth(); 
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /tasks/{taskId} {
      allow read:   if isAuth();
      allow create, update, delete: if hasOrgAccessForWrite();
    }

    match /info_items/{itemId} {
      allow read:   if isAuth();
      allow update: if isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedUserIds']);
      allow create, delete: if isAdmin() && hasOrgAccessForWrite();
    }

    match /issues/{issueId}     { allow read: if isAuth(); allow write: if hasOrgAccessForWrite(); }
    match /assets/{assetId}     { allow read: if isAuth(); allow write: if hasOrgAccessForWrite(); }
    match /requests/{requestId} { allow read: if isAuth(); allow write: if hasOrgAccessForWrite(); }

    // Detail collections
    match /parks_details/{docId}   { allow read: if isAuth(); allow write: if isAdmin() && hasOrgAccessForWrite(); }
    match /depots_details/{docId}  { allow read: if isAuth(); allow write: if isAdmin() && hasOrgAccessForWrite(); }
    match /machinery/{docId}       { allow read: if isAuth(); allow write: if isAdmin() && hasOrgAccessForWrite(); }
    match /smart_rules/{docId}     { allow read: if isAuth(); allow write: if isAdmin() && hasOrgAccessForWrite(); }

    // =============================================
    // Volunteering
    // =============================================
    match /volunteers/{volunteerId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // =============================================
    // Master fallback
    // =============================================
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}