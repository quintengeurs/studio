rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Rules for user management
    match /users/{userId} {
      // Allow anyone to read and create users.
      allow read, create: if true;
      // Only authenticated users can update or delete.
      allow update, delete: if isAuth();
    }

    // Rules for registry configuration
    match /settings/registry {
      // Allow anyone to read and write to the registry configuration.
      allow read, write: if true;
    }

    // Rules for locations
    match /locations/{locationId} {
      allow read, write: if true;
    }

    // Rules for tasks
    match /tasks/{taskId} {
      allow read, write: if true;
    }

    // Rules for issues
    match /issues/{issueId} {
      allow read, write: if true;
    }

    // Rules for requests
    match /requests/{requestId} {
      allow read, write: if true;
    }

    // Rules for public volunteering portal
    match /volunteers/{volunteerId} {
      // Allow anyone to register (create)
      allow create: if true;
      // Allow reading specific records by email (filtered query)
      allow read: if true;
      // Staff can update status
      allow update, delete: if isAuth();
    }

    match /info_items/{itemId} {
      // Allow anyone to read hub news
      allow read: if true;
      // Staff can manage
      allow create, update, delete: if isAuth();
    }

    match /parks_details/{parkId} {
      // Allow anyone to read park names
      allow read: if true;
      allow write: if isAuth();
    }

    // Catch-all rule: by default, require authentication for all other documents.
    match /{document=**} {
      allow read, write: if isAuth();
    }
  }
}
