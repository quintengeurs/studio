rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // Helper Functions
    // =============================================

    function isAuth() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuth() && request.auth.token.email.matches('(?i)quinten.geurs@gmail.com');
    }

    // Single document read - critical for performance
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"orgId": "hackney-council"};
    }

    function userOrgId() {
      return getUserData().orgId;
    }

    function belongsToOrg(orgId) {
      return isAuth() && (userOrgId() == orgId || isMaster());
    }

    function hasOrgAccess(data) {
      return isAuth() && (
        isMaster() || 
        (data != null && data.orgId == userOrgId())
      );
    }

    function hasOrgAccessForWrite() {
      return isAuth() && (
        isMaster() || 
        (request.resource.data.orgId == userOrgId())
      );
    }

    // =============================================
    // Rules
    // =============================================

    // Users
    match /users/{userId} {
      allow read:   if isMaster() || request.auth.uid == userId;
      allow create: if true;                    // Registration flow
      allow update: if isMaster() || request.auth.uid == userId;
      allow delete: if isMaster();
    }

    // Organizations
    match /organizations/{orgId} {
      allow read:  if true;                     // Public for branding / discovery
      allow write: if isMaster();

      match /role_templates/{roleId} {
        allow read:  if belongsToOrg(orgId);
        allow write: if belongsToOrg(orgId) && getUserData().role == 'Admin';
      }
    }

    // Park Activities (Central Registry)
    match /park_activities/{activityId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.type == 'Volunteering' && resource.data.status == 'Confirmed');
      allow create: if hasOrgAccessForWrite();
      allow update, delete: if hasOrgAccess(resource.data);
    }

    // Tasks
    match /tasks/{taskId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.isVolunteerEligible == true);
      allow create: if hasOrgAccessForWrite();
      allow update, delete: if hasOrgAccess(resource.data);
    }

    // Issues
    match /issues/{issueId} {
      allow read, create, update, delete: if hasOrgAccess(resource.data) || 
                                           hasOrgAccessForWrite();
    }

    // Assets
    match /assets/{assetId} {
      allow read, create, update, delete: if hasOrgAccess(resource.data) || 
                                           hasOrgAccessForWrite();
    }

    // Requests
    match /requests/{requestId} {
      allow read, create, update, delete: if isMaster() || hasOrgAccess(resource.data) || 
                                           hasOrgAccessForWrite();
    }

    // Org-specific data (parks, depots, machinery, smart rules, etc.)
    match /(parks_details|depots_details|machinery|smart_rules)/{docId} {
      allow read, create, update, delete: if hasOrgAccess(resource.data) || 
                                           hasOrgAccessForWrite();
    }

    // Settings (including subcollections)
    match /settings/{orgId} {
      allow read, write: if belongsToOrg(orgId);

      match /{allPaths=**} {
        allow read, write: if belongsToOrg(orgId);
      }
    }

    // Info Items (for volunteering portal)
    match /info_items/{itemId} {
      allow read:   if hasOrgAccess(resource.data) || 
                      (resource.data.isVolunteerVisible == true);
      
      // Allow full access for staff
      allow create, delete: if isAuth() && hasOrgAccessForWrite();
      
      // Special update rule: Allow staff OR unauthenticated interest registration
      allow update: if (isAuth() && hasOrgAccess(resource.data)) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedUserIds']));
    }

    // Volunteers (Public portal - legacy support)
    match /volunteers/{volunteerId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Action Logs
    match /action_logs/{logId} {
      allow read:   if isMaster() || hasOrgAccess(resource.data);
      allow create: if isAuth() && hasOrgAccessForWrite();
      allow update, delete: if false;
    }

    // Master fallback (catch-all)
    match /{document=**} {
      allow read, write: if isMaster();
    }
  }
}
